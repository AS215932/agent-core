{
  "additionalProperties": false,
  "description": "A cited source with optional A0-A5 authority (from the knowledge loop).",
  "properties": {
    "authority": {
      "anyOf": [
        {
          "enum": [
            "A0",
            "A1",
            "A2",
            "A3",
            "A4",
            "A5"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Authority"
    },
    "commit_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Commit Sha"
    },
    "excerpt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Excerpt"
    },
    "kind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Kind"
    },
    "ref": {
      "title": "Ref",
      "type": "string"
    },
    "review_status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review Status"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "ref"
  ],
  "title": "SourceRef",
  "type": "object"
}

          "type": "string"
        },
        "observation_window": {
          "$ref": "#/$defs/ImpactWindow"
        },
        "observed_score": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Score"
        },
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "safety_regressed": {
          "default": false,
          "title": "Safety Regressed",
          "type": "boolean"
        },
        "schema_version": {
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "score_delta": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score Delta"
        },
        "verdict": {
          "default": "inconclusive",
          "enum": [
            "better",
            "worse",
            "mixed",
            "inconclusive"

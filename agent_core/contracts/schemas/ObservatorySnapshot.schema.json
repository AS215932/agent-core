        },
        "origin": {
          "default": "",
          "title": "Origin",
          "type": "string"
        },
        "resolved_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved At"
        },
        "resource_id": {
          "default": "",
          "title": "Resource Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "default": "UNKNOWN",
          "title": "Severity",
          "type": "string"
        },
        "status": {
          "default": "",
          "title": "Status",
          "type": "string"

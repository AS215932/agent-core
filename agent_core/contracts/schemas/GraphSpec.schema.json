    "task_schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Schema"
    },
    "tool_bindings": {
      "additionalProperties": true,
      "title": "Tool Bindings",
      "type": "object"

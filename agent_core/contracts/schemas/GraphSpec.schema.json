          "title": "Kind",
          "type": "string"
        },
        "mcp_bindings": {
          "items": {
            "type": "string"
          },
          "title": "Mcp Bindings",
          "type": "array"
        },
        "memory_namespaces": {
          "items": {
            "type": "string"
          },
          "title": "Memory Namespaces",
          "type": "array"
        },
        "model_policy_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,

        "kind": {
          "enum": [
            "agent",
            "judge",
            "tool_executor",
            "mcp",
            "retriever",
            "memory",
            "policy",
            "human_approval",
            "subgraph",
            "parallel_council",
            "synthesizer",
            "system_node",
            "finalizer"
